#!/usr/bin/env bash
set -euo pipefail

refresh_desktop_caches() {
  if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications || true
  fi

  if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor || true
  fi
}

fix_chrome_sandbox() {
  local sandbox="/opt/minimax-hub/chrome-sandbox"
  [[ -e "${sandbox}" || -L "${sandbox}" ]] || return 0
  [[ ! -L "${sandbox}" ]] || { echo "Refusing to set setuid mode on symlink chrome-sandbox: ${sandbox}" >&2; return 1; }
  [[ -f "${sandbox}" ]] || { echo "Refusing to set setuid mode on non-regular chrome-sandbox: ${sandbox}" >&2; return 1; }
  [[ -x "${sandbox}" ]] || { echo "Refusing to set setuid mode on non-executable chrome-sandbox: ${sandbox}" >&2; return 1; }
  chown root:root "${sandbox}"
  chmod 4755 "${sandbox}"
}

case "${1:-configure}" in
  configure|triggered)
    fix_chrome_sandbox
    refresh_desktop_caches
    ;;
  *)
    ;;
esac

exit 0
